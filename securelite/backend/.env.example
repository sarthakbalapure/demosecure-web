PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/securelite
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Optional email alerts
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=replace_me
EMAIL_FROM=SecureLite <alerts@example.com>

# Optional OWASP ZAP integration
ZAP_BASE_URL=http://127.0.0.1:8080
ZAP_API_KEY=
USE_MOCK_SCANNER=true
ENABLE_WEEKLY_SCANS=false
WEEKLY_SCAN_CRON=0 9 * * 1
